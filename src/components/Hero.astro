---
import { site, getSocialUrl } from '../data/site';

interface Props {
  title?: string;
  subtitle?: string;
  role?: string;
  institution?: string;
}

const {
  title = site.author.name,
  subtitle = site.author.subtitle,
  role = site.author.role,
  institution = site.author.institution,
} = Astro.props;

const githubUrl = getSocialUrl('github');
const kclUrl = getSocialUrl('website');
---

<section class="relative py-20 md:py-28">
  <div class="max-w-4xl mx-auto px-4 animate-fade-in text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-3 text-gradient">
      {title}
    </h1>

    <p class="text-xl md:text-2xl text-accent mb-2">
      {subtitle}
    </p>

    <p class="text-sm md:text-base text-text-secondary mb-6">
      {institution}
    </p>

    <p class="text-base md:text-lg text-text-secondary mb-8 max-w-2xl mx-auto min-h-[1.75rem]">
      <span id="hero-typing" aria-label={role}></span><span class="typing-cursor" aria-hidden="true">|</span>
    </p>

    <!-- Quick Links -->
    <div class="flex flex-wrap justify-center gap-4 mb-8">
      <a href="/blog" class="btn">
        View Blog
      </a>
      <a href="/projects" class="btn-outline">
        Projects
      </a>
      <a href="/about" class="btn-outline">
        About Me
      </a>
    </div>

    <!-- Social Links -->
    <div class="flex justify-center gap-4">
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="p-3 rounded-lg bg-dark-surface border border-dark-border text-text-secondary hover:text-accent hover:border-accent/30 transition-all"
          aria-label="GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      )}

      <a
        href={`mailto:${site.author.emails.personal}`}
        class="p-3 rounded-lg bg-dark-surface border border-dark-border text-text-secondary hover:text-accent hover:border-accent/30 transition-all"
        aria-label="Email"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </a>

      {kclUrl && (
        <a
          href={kclUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="p-3 rounded-lg bg-dark-surface border border-dark-border text-text-secondary hover:text-accent hover:border-accent/30 transition-all"
          aria-label="KCL Profile"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
          </svg>
        </a>
      )}
    </div>
  </div>

  <!-- Decorative background -->
  <div class="absolute inset-0 overflow-hidden -z-10" aria-hidden="true">
    <div class="hero-grid-bg absolute inset-0"></div>
    <div class="bg-radial-fade absolute inset-0"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-3xl"></div>
  </div>
</section>

<script define:vars={{ role }}>
  const el = document.getElementById('hero-typing');
  if (!el) return;

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    el.textContent = role;
    return;
  }

  let i = 0;
  function type() {
    if (i <= role.length) {
      el.textContent = role.slice(0, i);
      i++;
      setTimeout(type, 38);
    }
  }
  setTimeout(type, 600);
</script>
