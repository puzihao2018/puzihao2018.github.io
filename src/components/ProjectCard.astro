---
interface Props {
  title: string;
  description?: string;
  slug?: string;
  demo?: string;
  github?: string;
  tags?: string[];
  image?: string;
}

const { title, description, slug, demo, github, tags = [], image } = Astro.props;
const detailHref = slug ? `/projects/${slug}` : undefined;
---

<article class="card group">
  {image && (
    <div class="aspect-video mb-4 rounded-lg overflow-hidden bg-dark-surface">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  )}

  <h3 class="text-xl font-semibold mb-2 group-hover:text-accent transition-colors">
    {detailHref ? <a href={detailHref} class="hover:text-accent transition-colors">{title}</a> : title}
  </h3>
  
  {description && (
    <p class="text-text-secondary mb-4 line-clamp-3">
      {description}
    </p>
  )}
  
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => (
        <span class="tag text-xs">
          {tag}
        </span>
      ))}
    </div>
  )}
  
  <div class="flex gap-4">
    {detailHref && (
      <a href={detailHref} class="btn text-sm py-2 px-4">
        Read More
      </a>
    )}

    {demo && (
      <a
        href={demo}
        target="_blank"
        rel="noopener noreferrer"
        class="btn text-sm py-2 px-4"
      >
        Live Demo
      </a>
    )}
    
    {github && (
      <a 
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline text-sm py-2 px-4 inline-flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    )}
  </div>
</article>