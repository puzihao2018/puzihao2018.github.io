---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Contact Zihao Pu - Email, GitHub, KCL Profile">
  <div class="max-w-4xl mx-auto px-4 py-12 animate-fade-in">
    <!-- Page Header -->
    <header class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Me</h1>
      <p class="text-xl text-text-secondary">
        Feel free to reach out for collaboration, questions, or discussions.
      </p>
    </header>
    
    <!-- Contact Methods -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <!-- Email -->
      <div class="card text-center">
        <div class="mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-accent">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <h2 class="text-xl font-semibold mb-2">Email</h2>
        <p class="text-text-secondary mb-4">
          The most direct way to contact me
        </p>
        <a 
          href="mailto:zihao.pu@zihaopu.cn"
          class="btn"
        >
          zihao.pu@zihaopu.cn
        </a>
      </div>
      
      <!-- GitHub -->
      <div class="card text-center">
        <div class="mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="mx-auto text-accent">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </div>
        <h2 class="text-xl font-semibold mb-2">GitHub</h2>
        <p class="text-text-secondary mb-4">
          View my open-source projects and code
        </p>
        <a 
          href="https://github.com/puzihao2018"
          target="_blank"
          rel="noopener noreferrer"
          class="btn"
        >
          puzihao2018
        </a>
      </div>
      
      <!-- KCL Profile -->
      <div class="card text-center">
        <div class="mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-accent">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
          </svg>
        </div>
        <h2 class="text-xl font-semibold mb-2">KCL Academic Profile</h2>
        <p class="text-text-secondary mb-4">
          Official university profile page
        </p>
        <a 
          href="https://www.kcl.ac.uk/people/zihao-pu"
          target="_blank"
          rel="noopener noreferrer"
          class="btn"
        >
          View Profile
        </a>
      </div>
      
      <!-- University Email -->
      <div class="card text-center">
        <div class="mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-accent">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <h2 class="text-xl font-semibold mb-2">University Email</h2>
        <p class="text-text-secondary mb-4">
          For academic and research inquiries
        </p>
        <a 
          href="mailto:zihao.pu@kcl.ac.uk"
          class="btn"
        >
          zihao.pu@kcl.ac.uk
        </a>
      </div>
    </div>
    
    <!-- Additional Info -->
    <div class="card max-w-2xl mx-auto text-center">
      <h3 class="text-xl font-semibold mb-4">Office Hours</h3>
      <p class="text-text-secondary">
        I typically respond during work hours (9:00 - 18:00 UTC+8) on weekdays. 
        For urgent matters, please email directly.
      </p>
    </div>
  </div>
</BaseLayout>