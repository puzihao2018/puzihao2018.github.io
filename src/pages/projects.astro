---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getSocialUrl } from '../data/site';

const allProjects = await getCollection('projects', ({ data }) => data.published !== false);
const projects = allProjects.sort((a, b) => {
  if (a.data.date && b.data.date) return b.data.date.getTime() - a.data.date.getTime();
  return 0;
});
---

<BaseLayout title="Projects" description="Zihao Pu's Projects - FPGA, Embedded Systems, Hardware Design, AI Acceleration">
  <div class="max-w-6xl mx-auto px-4 py-12 animate-fade-in">
    <!-- Page Header -->
    <header class="mb-12 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Projects</h1>
      <p class="text-xl text-text-secondary">
        FPGA · Embedded Systems · Hardware Acceleration · AI Systems
      </p>
    </header>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      {projects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          tags={project.data.tags}
          github={project.data.github}
          demo={project.data.demo}
          image={project.data.image}
          slug={project.slug}
        />
      ))}
    </div>

    <!-- GitHub Link -->
    <div class="mt-12 text-center">
      <div class="card max-w-md mx-auto">
        <h3 class="text-xl font-semibold mb-4">View More Projects</h3>
        <p class="text-text-secondary mb-6">
          Check out all my open-source projects and code on GitHub.
        </p>
        <a
          href={getSocialUrl('github')!}
          target="_blank"
          rel="noopener noreferrer"
          class="btn inline-flex items-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Visit GitHub
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
